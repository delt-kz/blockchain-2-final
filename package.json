{
  "name": "blockchain-final",
  "version": "1.0.0",
  "description": "Final project smart contracts for a DeFi super-app protocol.",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "forge:build": "forge build",
    "forge:test": "forge test",
    "forge:coverage": "forge coverage --report lcov && node scripts/checkForgeCoverage.js lcov.info 90",
    "slither": "python -m slither . --filter-paths \"node_modules|artifacts|cache|coverage|typechain-types|test|lib\" --fail-medium",
    "lint:sol": "forge fmt --check && npx solhint \"contracts/**/*.sol\"",
    "lint:frontend": "npx prettier --check \"frontend/src/**/*.{ts,tsx,css}\"",
    "build:frontend": "cd frontend && npm ci && npm run build",
    "build:subgraph": "cd subgraph && npm ci && npm run build",
    "security": "npm run lint:sol && npm run slither && npm run forge:coverage",
    "deploy:arb-sepolia": "hardhat run scripts/deploy.ts --network arbitrumSepolia",
    "deploy:op-sepolia": "hardhat run scripts/deploy.ts --network optimismSepolia",
    "deploy:base-sepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "verify:deployment": "hardhat run scripts/verifyDeployment.ts",
    "verify:deployment:base-sepolia": "hardhat run scripts/verifyDeployment.ts --network baseSepolia",
    "verify:contracts": "hardhat run scripts/verifyContracts.ts",
    "verify:contracts:base-sepolia": "hardhat run scripts/verifyContracts.ts --network baseSepolia",
    "fix:deployment-ownership": "hardhat run scripts/fixDeploymentOwnership.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@types/node": "^25.8.0",
    "hardhat": "^2.28.6",
    "prettier": "^3.8.3",
    "solhint": "^6.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "dotenv": "^17.4.2"
  }
}
